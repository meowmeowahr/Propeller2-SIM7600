{Spin2_v53}

''
'   File....... ka_sim7600.spin2
'   Purpose.... Object for SIMCOM SIM7600 4G/3G/2G Cellular Modem
'   Authors.... Kevin Ahr
'               -- see below for terms of use
'   E-mail..... meowmeowahr@gmail.com
'   Started.... 04 JUN 2026
'   Updated.... 05 JUN 2026
''

CON

    MAX_LINE_LENGTH   = 1024
    MAX_RESPONSE      = 8192
    PAYLOAD_BUF_SIZE  = 32

CON

    #0, MODE_MINIMUM, MODE_FULL
    #4, MODE_FLIGHT, MODE_FACTORY_TEST, MODE_RESET, MODE_OFFLINE

    #0, DRIVER_NOT_STARTED, DRIVER_STARTING, DRIVER_READY, DRIVER_RESETTING

    #0, RESULT_OK, RESULT_ERROR, RESULT_CME_ERROR, RESULT_CMS_ERROR, RESULT_ABORTED, RESULT_PROMPT

    #0, URC_NONE, URC_MQTT_RX_PAYLOADSTART, URC_MQTT_RX_PAYLOAD

OBJ
    ser         : "jm_fullduplexserial"
    nstr        : "jm_nstr"
    str         : "string"

    fifoRx      : "ka_ring_buffer"
    fifoUrc     : "ka_ring_buffer"

VAR
    BYTE    rxP, txP, dtrP, rstP
    LONG    baudRate

    BYTE    cogId
    BYTE    driverState

    ' Payload ring buffer (replaces simple_ring_buffer object)
    LONG    payload_ring_ptr                                        ' pointer to byte array
    LONG    payload_ring_mask                                       ' size-1 for fast wrapping
    LONG    payload_head                                            ' write position
    LONG    payload_tail                                            ' read position

    BYTE    inWaitingCommand[MAX_LINE_LENGTH]
    BYTE    inWaitingEchoed
    BYTE    inWaitingCompleted
    BYTE    commandResultCode

    BYTE    responseBuffer[MAX_RESPONSE]

    WORD    lastCmeError, lastCmsError

    BYTE    modemStack[MAX_LINE_LENGTH + 256]

    BYTE    doInitialReset

    BYTE    modemIsReady, smsIsReady, phonebookIsReady, simIsReady

' Payload streaming
    BYTE    payloadBuffer[PAYLOAD_BUF_SIZE]
    LONG    inWaitingPayloadLen                                     ' Total expected bytes (for progress)
    LONG    payloadSent                                             ' How many bytes already sent

    BYTE    mqttClientNum
    WORD    mqttPayloadExpected
    WORD    mqttPayloadLen
    BYTE    inMqttPayload
    BYTE    mqttPayloadReady
    BYTE    mqttPayloadBuffer[MAX_RESPONSE]                         ' Buffer to hold MQTT payload data

    WORD    mqttTopicExpected
    WORD    mqttTopicLen
    BYTE    inMqttTopic
    BYTE    mqttTopicBuffer[MAX_LINE_LENGTH]

    ' MQTT Publish Streaming
    BYTE    mqttPublishClientNum
    WORD    mqttPublishTopicLen
    WORD    mqttPublishPayloadLen
    WORD    mqttPublishPayloadSent
    BYTE    mqttPublishQos
    BYTE    mqttPublishRetain
    WORD    mqttPublishTimeout
    BYTE    mqttPublishTopicSet
    BYTE    mqttPublishLenSet

    BYTE    inWaitingForPrompt

    BYTE    mqttStartResult
    WORD    mqttConnectResult

PUB null()
' this is not a top-level object


PUB start(rxPin, txPin, dtrPin, rstPin, baud, doReset, pRxBuffer, rxBufferSize, pUrcBuffer, urcBufferSize)
    dtrP := dtrPin
    rstP := rstPin
    rxP := rxPin
    txP := txPin
    baudRate := baud

    ser.start(rxP, txP, %0000, baudRate)

    doInitialReset := doReset
    modemIsReady, smsIsReady, phonebookIsReady, simIsReady := false, false, false, false
    inWaitingEchoed, inWaitingCompleted := false, false
    driverState := DRIVER_STARTING

    cogId := cogspin(newcog, modemCog(), @modemStack)

    fifoRx.ringBufferInit(pRxBuffer, rxBufferSize)
    fifoUrc.ringBufferInit(pUrcBuffer, urcBufferSize)
    mqttPayloadLen := 0
    mqttPayloadExpected := 0
    mqttClientNum := 0
    inMqttPayload := 0
    mqttPayloadReady := 0
    bytefill(@mqttPayloadBuffer, 0, MAX_RESPONSE)

    payload_init(@payloadBuffer, PAYLOAD_BUF_SIZE)
    inWaitingPayloadLen := 0
    payloadSent := 0

    mqttTopicLen := 0
    mqttTopicExpected := 0
    inMqttTopic := 0
    bytefill(@mqttTopicBuffer, 0, MAX_LINE_LENGTH)

    inWaitingPayloadLen := 0
    inWaitingForPrompt := false
    mqttConnectResult := $FF

    mqttStartResult := 255


PUB stop()

    ser.stop()
    cogstop(cogId)


PUB hardReset()

    pinh(rstP)
    modemIsReady := false
    driverState := DRIVER_RESETTING
    waitms(200)
    pinl(rstP)
    driverState := DRIVER_STARTING


PUB isCommandRunning() : r
    r := inWaitingCompleted == false


PUB getCommandResult() : r
    r := commandResultCode


PUB getCommandResponse() : r
    r := @responseBuffer


PUB getInWaitingUrcType() : r
    if fifoUrc.ringBufferIsEmpty()
        r := URC_NONE
        return

    ' Peek at the first URC in buffer to determine type
    fifoUrc.ringBufferPeekStr(@rxP, MAX_LINE_LENGTH)    ' Use rxP as temp buffer
    if str.startswith(@rxP, @"+CMQTTRXPAYLOAD: ")
        r := URC_MQTT_RX_PAYLOADSTART
    elseif str.startswith(@rxP, @"+CMQTTRXEND: ")
        r := URC_MQTT_RX_PAYLOAD
    else
        r := URC_NONE                                   ' Shouldn't happen if we only put MQTT URCs in buffer


PUB popInWaitingUrc()
    fifoUrc.ringBufferDrop()


PUB getInWaitingMqttPayload(pDst, maxLen) : r | lenToCopy
' Check if we have a payload ready (i.e., we have received the END URC for a buffered PAYSTART)

    ifnot mqttPayloadReady
        r := RESULT_ERROR
        return

    ' Check that there is at least one URC in the buffer
    if fifoUrc.ringBufferIsEmpty()
        r := RESULT_ERROR
        return

    ' Optional: verify that the first URC is indeed a CMQTTRXEND URC
    fifoUrc.ringBufferPeekStr(@rxP, MAX_LINE_LENGTH)
    ifnot str.startswith(@rxP, @"+CMQTTRXEND: ")
        r := RESULT_ERROR
        return

    ' Remove the URC from the buffer
    fifoUrc.ringBufferReadStr(@rxP, MAX_LINE_LENGTH)

    ' Copy the payload data to the destination buffer
    lenToCopy := mqttPayloadLen <# maxLen               ' Lesser of actual length or max allowed
    bytemove(pDst, @mqttPayloadBuffer, lenToCopy)
    BYTE[pDst][lenToCopy] := 0                          ' Null terminate

    ' Reset MQTT state
    mqttPayloadLen := 0
    mqttPayloadExpected := 0
    mqttTopicLen := 0
    mqttTopicExpected := 0
    mqttClientNum := 0
    inMqttPayload := 0
    inMqttTopic := 0
    mqttPayloadReady := 0

    r := RESULT_OK


PUB isReady() : ready
    ready := modemIsReady && smsIsReady && simIsReady


PUB getModemFirmwareRevision(p_resp, maxLen) : r

    sendCommand(@"AT+CGMR")

    repeat while isCommandRunning()

    strcopy(p_resp, getCommandResponse()+7, maxLen)

    r := getCommandResult()


PUB getModemModel(p_resp, maxLen) : r

    r := runCommandAndGetResponse(@"AT+CGMM", p_resp, maxLen)


PUB getModemManufacturer(p_resp, maxLen) : r

    r := runCommandAndGetResponse(@"AT+CGMI", p_resp, maxLen)


PUB getModemSerialNumber(p_resp, maxLen) : r

    r := runCommandAndGetResponse(@"AT+CGSN", p_resp, maxLen)


PUB startOperatorSearch()

    sendCommand(@"AT+COPS=?")


PUB stopOperatorSearch()

    ser.tx(32)                                          ' Send space as interrupt


PUB isOperatorSearching() : r
    r := isCommandRunning()


PUB getOperatorCount() : r | addr, count, tmpAddr, isOperator

    addr := findCopsStart()
    if addr == -1
        return 0

    count := 0
    repeat while (BYTE[addr] <> 0) AND (BYTE[addr] <> 13)
        if BYTE[addr] == "("
            ' The operator blocks start with (status, "name", "reg", "plmn", access)
            ' The trailing blocks are (0,1,2,3,4,5) and (0,1,2)
            ' distinguish by checking if the block contains a quote

            tmpAddr := addr
            isOperator := false
            repeat while (BYTE[tmpAddr] <> ")") AND (BYTE[tmpAddr] <> 0)
                if BYTE[tmpAddr] == 34
                    isOperator := true
                    quit
                tmpAddr++

            if isOperator
                count++
        addr++
    r := count


PUB getOperatorName(index, p_name, maxLen) : r | addr, found, i

    addr := findCopsStart()
    if addr == -1
        return RESULT_ERROR

    found := 0
    repeat while (BYTE[addr] <> 0) AND (BYTE[addr] <> 13)
        if BYTE[addr] == "("
            if found == index
                addr++                                  ' skip (
                repeat while (BYTE[addr] <> ",") AND (BYTE[addr] <> 0)
                    addr++
                addr++                                  ' skip comma

                ' Skip leading quote
                repeat while (BYTE[addr] == 34 OR BYTE[addr] == 147 OR BYTE[addr] == 148)
                    addr++

                i := 0
                repeat while (BYTE[addr] <> 34 AND BYTE[addr] <> 148 AND BYTE[addr] <> 149 AND BYTE[addr] <> 0) AND (i < maxLen - 1)
                    BYTE[p_name + i] := BYTE[addr]
                    addr++
                    i++
                BYTE[p_name + i] := 0
                return RESULT_OK
            found++
        addr++
    r := RESULT_ERROR


PUB getOperatorHNI(index, p_hni, maxLen) : r | addr, found, commaCount, i

    addr := findCopsStart()
    if addr == -1
        return RESULT_ERROR

    found := 0
    repeat while (BYTE[addr] <> 0) AND (BYTE[addr] <> 13)
        if BYTE[addr] == "("
            if found == index
                commaCount := 0
                repeat while (BYTE[addr] <> ")") AND (BYTE[addr] <> 0)
                    if BYTE[addr] == ","
                        commaCount++
                        if commaCount == 3
                            addr++                      ' skip 3rd comma
                            repeat while (BYTE[addr] == 34 OR BYTE[addr] == 147 OR BYTE[addr] == 148)
                                addr++

                            i := 0
                            repeat while (BYTE[addr] <> 34 AND BYTE[addr] <> 148 AND BYTE[addr] <> 149 AND BYTE[addr] <> 0) AND (i < maxLen - 1)
                                BYTE[p_hni + i] := BYTE[addr]
                                addr++
                                i++
                            BYTE[p_hni + i] := 0
                            return RESULT_OK
                    addr++
            found++
        addr++
    r := RESULT_ERROR


PRI findCopsStart() : addr

    addr := @responseBuffer
    repeat while (BYTE[addr] <> 0)
        if str.startswith(addr, @"+COPS: ")
            return addr + 7
        addr++
    return -1


PUB getSupportedBaudRates(pBuf, maxLen) : count | tmp[128], src, val, pOut, i

    count := -1
    if runCommandAndGetResponse(string("AT+IPR=?"), @tmp, 128) <> RESULT_OK
        return

    src := @tmp

    if (BYTE[src] == "+")
        src += strsize(string("+IPR:"))

    repeat while (BYTE[src] == " ")
        src++

    if BYTE[src] == "("
        src++

    pOut := pBuf
    i := 0

    repeat while (BYTE[src] <> 0) AND (BYTE[src] <> 10) AND (BYTE[src] <> ")") AND (i < maxLen)
        repeat while (BYTE[src] == ",")
            src++
        if BYTE[src] == ")"
            quit

        val := str.atoi(src)

        repeat while (BYTE[src] >= "0") AND (BYTE[src] <= "9")
            src++

        LONG[pOut][0] := val
        pOut += 4
        i++

    count := i


PUB setPermanentBaudRate(baud) : status | tmp[24]

    str.sprintf1(@tmp, @"AT+IPREX=%d\000", baud)
    status := runCommand(@tmp)


PUB getModemSignalStrength(p_rssi, p_ber) : r | resp[24], respAddr, rssi[4], ber[3], BYTE i

    r := runCommandAndGetResponse(@"AT+CSQ", @resp, 24)
    respAddr := @resp+5
    i := 0
    repeat while BYTE[++respAddr] <> ","
        BYTE[@rssi+i++] := BYTE[respAddr]
    i := 0
    repeat while BYTE[++respAddr] <> 0
        BYTE[@ber+i++] := BYTE[respAddr]
    BYTE[p_rssi] := str.atoi(@rssi)
    BYTE[p_ber] := str.atoi(@ber)


PRI runCommand(p_cmdStr) : r
    sendCommand(p_cmdStr)
    repeat while isCommandRunning()
    r := getCommandResult()


PRI runBlindCommandForPrompt(p_cmdStr)
    sendCommand(p_cmdStr)
    repeat while (inWaitingForPrompt == true) or (inWaitingEchoed == false)


PRI runCommandWithPayload(p_cmdStr, p_payload, payloadLen) : r | i
'' Send command + payload. p_payload can be small buffer or streamed later.

    inWaitingPayloadLen := payloadLen
    payloadSent := 0
    payload_flush()

    ' If small payload, preload into ring buffer
    if payloadLen <= PAYLOAD_BUF_SIZE
        repeat i from 0 to payloadLen-1
            payload_put(BYTE[p_payload][i])
    else
        ' Large payload: user must call feedPayload() before prompt arrives
        debug("Large payload: use feedPayload()")

    inWaitingForPrompt := true
    sendCommand(p_cmdStr)
    repeat while isCommandRunning()
    r := getCommandResult()

' New helper for large/streaming payloads
PUB feedPayload(p_data, len) : sent
'' Feed data into the payload stream (call repeatedly for large files)

    sent := 0
    repeat len
        if payload_put(BYTE[p_data][sent])
            sent++
        else
            ' Buffer full - caller should wait a bit
            quit
    return sent


PRI runCommandAndGetResponse(p_cmdStr, p_resp, maxLen) : r
    sendCommand(p_cmdStr)
    repeat while isCommandRunning()
    strcopy(p_resp, getCommandResponse(), maxLen)
    r := getCommandResult()


PRI sendCommand(p_cmdStr) | cmdLen

    cmdLen := strsize(p_cmdStr)
    if cmdLen > MAX_LINE_LENGTH - 1
        debug("Command too long to send")
        return

    inWaitingEchoed := false
    inWaitingCompleted := false
    bytefill(@responseBuffer, 0, MAX_RESPONSE)
    ser.str(p_cmdStr)
    ser.tx(ser.CR)
    str.copy(@inWaitingCommand, p_cmdStr)
    debug("Send command: ", zstr_(p_cmdStr))


PRI onConnect()


PRI markModemReady()
    modemIsReady := true
    onConnect()


PRI appendResponse(buf) | len, responseLen

    len := strsize(buf)

    if len + 2 >= MAX_RESPONSE
        debug("ERR: response overflow")
        return

    bytemove(@responseBuffer + responseLen, buf, len)
    responseLen += len

    BYTE[responseBuffer][responseLen++] := 13
    BYTE[responseBuffer][responseLen++] := 10
    BYTE[responseBuffer][responseLen] := 0


PRI modemCog() | inChar, buf[MAX_LINE_LENGTH], addr, len, clientNumFromUrc, i
    if doInitialReset
        hardReset()
    else
        sendCommand(@"AT")

    repeat
        repeat
            inChar := ser.rxCheck()
            case inChar
                -1:                                     ' no data
                    quit
                10, 13:
                    fifoRx.ringBufferCommit()
                    quit                                ' quit to handle echo in case ">" is the next char
                ">":
                    if inWaitingForPrompt
                        inWaitingForPrompt := false
                        debug(udec(inWaitingEchoed))
                        streamPayloadToModem()
                    else
                        fifoRx.ringBufferPut(inChar)
                other:
                    fifoRx.ringBufferPut(inChar)

        repeat while fifoRx.ringBufferCount() > 0
            fifoRx.ringBufferReadStr(@buf, MAX_LINE_LENGTH)
            debug("RX: ", zstr(@buf))

            ' urcs
            if strcomp(@buf, @"RDY")
                markModemReady()
                debug("Modem marked as ready")
                driverState := DRIVER_READY
            elseif strcomp(@buf, @"SMS DONE")
                smsIsReady := true
                debug("SMS subsystem marked as ready")
            elseif strcomp(@buf, @"PB DONE")
                phonebookIsReady := true
                debug("Phonebook subsystem marked as ready")
            elseif strcomp(@buf, @"+CPIN: READY")
                simIsReady := true
                debug("SIM subsystem marked as ready")
            ' MQTT URCs - buffer for later processing
            elseif str.startswith(@buf, @"+CMQTTSTART: ")
                debug("MQTT RX Start URC: ", zstr(@buf))
                mqttStartResult := str.atoi(@buf + 14)
            elseif str.startswith(@buf, @"+CMQTTRXSTART: ")
                debug("MQTT RX Start URC: ", zstr(@buf))
            elseif str.startswith(@buf, @"+CMQTTRXTOPIC: ")
                addr := @buf + 16                       ' Skip "+CMQTTRXTOPIC: "
                mqttClientNum := str.atoi(addr)
                repeat while BYTE[addr] <> "," and BYTE[addr] <> 0
                    addr++
                if BYTE[addr] == ","
                    addr++
                    mqttTopicExpected := str.atoi(addr)
                else
                    mqttTopicExpected := 0
                mqttTopicLen := 0
                inMqttTopic := 1
                bytefill(@mqttTopicBuffer, 0, MAX_LINE_LENGTH)
                debug("MQTT RX Topic URC: client=", udec(mqttClientNum), " bytes=", udec(mqttTopicExpected))
            elseif str.startswith(@buf, @"+CMQTTRXPAYLOAD: ")
                addr := @buf + 18                       ' Skip "+CMQTTRXPAYLOAD: "
                mqttClientNum := str.atoi(addr)
                repeat while BYTE[addr] <> "," and BYTE[addr] <> 0
                    addr++
                if BYTE[addr] == ","
                    addr++
                    mqttPayloadExpected := str.atoi(addr)
                else
                    mqttPayloadExpected := 0
                mqttPayloadLen := 0
                inMqttPayload := 1
                bytefill(@mqttPayloadBuffer, 0, MAX_RESPONSE)
                debug("MQTT RX Payload URC: client=", udec(mqttClientNum), " bytes=", udec(mqttPayloadExpected))
            elseif str.startswith(@buf, @"+CMQTTRXEND: ")
                ' Verify this END matches our expected client
                addr := @buf + 13                       ' Skip "+CMQTTRXEND: "
                clientNumFromUrc := str.atoi(addr)
                if mqttClientNum == clientNumFromUrc
                    inMqttPayload := 0                  ' Done receiving payload
                    mqttPayloadReady := 1               ' Payload ready for retrieval

                    ' Queue the URC to notify the client
                    fifoUrc.ringBufferWriteStr(@buf)
                    fifoUrc.ringBufferCommit()
                    debug("MQTT RX End URC matched client=", udec(mqttClientNum), " URC=", zstr(@buf))
                else
                    debug("MQTT END URC client mismatch: expected=", udec(mqttClientNum), " got=", udec(clientNumFromUrc))
            elseif str.startswith(@buf, @"+CMQTTCONNECT: ")
                addr := @buf + 15                       ' Skip "+CMQTTCONNECT: "
                clientNumFromUrc := str.atoi(addr)
                repeat while BYTE[addr] <> "," and BYTE[addr] <> 0
                    addr++
                if BYTE[addr] == ","
                    addr++
                    mqttConnectResult := str.atoi(addr)
                else
                    mqttConnectResult := 1              ' Error
                debug("MQTT Connect Result URC: client=", udec(clientNumFromUrc), " result=", udec(mqttConnectResult))

            ' Handle incoming MQTT topic data
            elseif inMqttTopic
                len := strsize(@buf)
                if mqttTopicLen + len < MAX_LINE_LENGTH
                    bytemove(@mqttTopicBuffer + mqttTopicLen, @buf, len)
                    mqttTopicLen += len
                    debug("MQTT topic byte received, len=", udec(len), " total=", udec(mqttTopicLen), "/", udec(mqttTopicExpected))
                else
                    debug("MQTT topic buffer overflow!")
                    inMqttTopic := 0

                if mqttTopicLen >= mqttTopicExpected
                    inMqttTopic := 0
                    debug("MQTT topic complete: ", zstr(@mqttTopicBuffer))

            ' Handle incoming MQTT payload data
            elseif inMqttPayload
                ' Add this line's data to our payload buffer
                len := strsize(@buf)                    ' Get length of this line
                if mqttPayloadLen + len < MAX_RESPONSE
                    bytemove(@mqttPayloadBuffer + mqttPayloadLen, @buf, len)
                    mqttPayloadLen += len
                    debug("MQTT payload byte received, len=", udec(len), " total=", udec(mqttPayloadLen), "/", udec(mqttPayloadExpected))
                else
                    debug("MQTT payload buffer overflow!")
                    inMqttPayload := 0                  ' Reset on error

                ' Check if we've received all expected data
                if mqttPayloadLen >= mqttPayloadExpected
                    debug("MQTT payload complete: ", udec(mqttPayloadLen), " bytes received")

            ' response
            elseif strcomp(@buf, @inWaitingCommand)
                inWaitingEchoed := true
                inWaitingCompleted := false
                debug("Command echoed back")
            elseif strcomp(@buf, @"OK")
                ifnot modemIsReady
                    markModemReady()                    ' from initial AT
                    smsIsReady := true                  ' TODO: there might be a better way to detect subsystem readiness
                    phonebookIsReady := true
                    simIsReady := true
                if inWaitingEchoed
                    commandResultCode := RESULT_OK
                    inWaitingCompleted := true
                    debug("Command completed with OK", zstr(@inWaitingCommand))
                else
                    debug("Received OK without command echo, ignoring")
            elseif strcomp(@buf, @"ERROR")
                if inWaitingEchoed
                    commandResultCode := RESULT_ERROR
                    inWaitingCompleted := true
                    debug("Command completed with ERROR")
                else
                    debug("Received ERROR without command echo, ignoring")
            elseif str.startswith(@buf, @"+CME ERROR: ")
                commandResultCode := RESULT_CME_ERROR
                inWaitingCompleted := true
                debug("Command completed with CME ERROR")
                ' read number value
                lastCmeError := str.atoi(@buf+12)
            elseif str.startswith(@buf, @"+CMS ERROR: ")
                commandResultCode := RESULT_CMS_ERROR
                inWaitingCompleted := true
                debug("Command completed with CMS ERROR")
                ' read number value
                lastCmsError := str.atoi(@buf+12)
            elseif inWaitingCompleted == false
                appendResponse(@buf)
            else
                debug("ERR: Received unrecognized response: ", zstr(@buf))


PRI streamPayloadToModem() | c
'' Stream payload from ring buffer to modem when > prompt received

    payloadSent := 0
    debug("Streaming payload to modem, total bytes: ", udec(inWaitingPayloadLen))
    repeat while (payload_available() > 0) or (payloadSent < inWaitingPayloadLen)
        c := payload_get()
        if c == -1
            next
        ser.tx(c)
        payloadSent++

    debug("Payload streamed: ", udec(payloadSent), " / ", udec(inWaitingPayloadLen))


PRI payload_init(pRing, size) | i
    payload_ring_ptr := pRing
    payload_ring_mask := size - 1
    payload_head := 0
    payload_tail := 0
    bytefill(payload_ring_ptr, 0, size)


PRI payload_put(c) : ok
    if ((payload_head + 1) & payload_ring_mask) == payload_tail
        return false

    BYTE[payload_ring_ptr][payload_head] := c
    payload_head := (payload_head + 1) & payload_ring_mask
    ok := true


PRI payload_get() : b
    if (payload_head == payload_tail)
        return -1

    b := BYTE[payload_ring_ptr][payload_tail]
    payload_tail := (payload_tail + 1) & payload_ring_mask
    return b


PRI payload_available() : c
    c := (payload_head - payload_tail) & payload_ring_mask


PRI payload_flush()
    payload_head := 0
    payload_tail := 0


PUB getInWaitingMqttTopic(pDst, maxLen) : r | lenToCopy
' Check if we have a payload/topic ready

    ifnot mqttPayloadReady
        r := RESULT_ERROR
        return

    ' Copy the topic data to the destination buffer
    lenToCopy := mqttTopicLen <# maxLen                 ' Lesser of actual length or max allowed
    bytemove(pDst, @mqttTopicBuffer, lenToCopy)
    BYTE[pDst][lenToCopy] := 0                          ' Null terminate

    r := RESULT_OK


PUB mqttStart() : r
    r := runCommand(@"AT+CMQTTSTART")
    if r <> 0
        return r
    repeat while mqttStartResult == 255
    r := mqttStartResult


PUB mqttStop() : r
    r := runCommand(@"AT+CMQTTSTOP")


PUB mqttAcquireClient(clientNum, pClientName) : r | tmp[128]
    str.sprintf4(@tmp, @"AT+CMQTTACCQ=%d,%c%s%c\000", clientNum, 34, pClientName, 34)
    r := runCommand(@tmp)


PUB mqttWillTopic(clientNum, pWillTopic) : r | topicLen, tmp[64]
    topicLen := strsize(pWillTopic)
    str.sprintf2(@tmp, @"AT+CMQTTWILLTOPIC=%d,%d\000", clientNum, topicLen)
    r := runCommandWithPayload(@tmp, pWillTopic, topicLen)


PUB mqttWillMsg(clientNum, pWillMsg, qos) : r | msgLen, tmp[64]
    msgLen := strsize(pWillMsg)
    str.sprintf3(@tmp, @"AT+CMQTTWILLMSG=%d,%d,%d\000", clientNum, msgLen, qos)
    r := runCommandWithPayload(@tmp, pWillMsg, msgLen)


PUB mqttConnect(clientNum, pAddress, keepAlive, cleanSession, pUsername, pPassword) : r | tmp[512], tmp2[128], args[6]
    args[0] := clientNum
    args[1] := 34
    args[2] := pAddress
    args[3] := 34
    args[4] := keepAlive
    args[5] := cleanSession
    str.sprintf(@tmp, @"AT+CMQTTCONNECT=%d,%c%s%c,%d,%d\000", @args)

    if pUsername <> 0 and strsize(pUsername) > 0
        str.sprintf3(@tmp2, @",%c%s%c\000", 34, pUsername, 34)
        str.append(@tmp, @tmp2)
        if pPassword <> 0 and strsize(pPassword) > 0
            str.sprintf3(@tmp2, @",%c%s%c\000", 34, pPassword, 34)
            str.append(@tmp, @tmp2)

    mqttConnectResult := $FF
    r := runCommand(@tmp)
    if r <> RESULT_OK
        return r

    ' Wait for the +CMQTTCONNECT: <client_index>,<err_code> URC
    ' Wait up to 20 seconds (400 * 50ms)
    repeat 400
        if mqttConnectResult <> $FF
            quit
        waitms(50)

    if mqttConnectResult == 0
        r := RESULT_OK
    else
        r := RESULT_ERROR


PUB mqttSubscribe(clientNum, pTopic, qos) : r | topicLen, tmp[64]
    topicLen := strsize(pTopic)
    ' 1. Set subscription topic (which expects a prompt and payload)
    str.sprintf3(@tmp, @"AT+CMQTTSUBTOPIC=%d,%d,%d\000", clientNum, topicLen, qos)
    r := runCommandWithPayload(@tmp, pTopic, topicLen)
    if r <> RESULT_OK
        return r

    ' 2. Execute subscription
    str.sprintf1(@tmp, @"AT+CMQTTSUB=%d\000", clientNum)
    r := runCommand(@tmp)


PUB mqttPublish(clientNum, pTopic, qos, retain, timeout, pPayload) : r | topicLen, payloadLen, tmp[128] ' 128 limits you to a 111-byte topic and 108-byte payload. Module hard limits are 1024/10240 respectively.
    topicLen := strsize(pTopic)
    payloadLen := strsize(pPayload)

    str.sprintf2(@tmp, @"AT+CMQTTTOPIC=%d,%d\000", clientNum, topicLen)
    r := runCommandWithPayload(@tmp, pTopic, topicLen)
    if r <> RESULT_OK
        return r

    str.sprintf2(@tmp, @"AT+CMQTTPAYLOAD=%d,%d\000", clientNum, payloadLen)
    r := runCommandWithPayload(@tmp, pPayload, payloadLen)
    if r <> RESULT_OK
        return r

    str.sprintf4(@tmp, @"AT+CMQTTPUB=%d,%d,%d,%d\000", clientNum, qos, timeout, retain)
    r := runCommand(@tmp)


PUB startMqttPublishStream(clientNum, pTopic, qos, retain, timeout, length) : r | topicLen, tmp[128] ' 128 limits you to a 111-byte topic. Module hard limit is 1024.
'' Start an MQTT publish stream for sending large payloads
'' clientNum: MQTT client identifier
'' pTopic: Topic string to publish to
'' qos: Quality of Service (0, 1, or 2)
'' retain: Retain flag (0 or 1)
'' timeout: Timeout in seconds
'' length: Total payload length in bytes

    mqttPublishClientNum := clientNum
    mqttPublishQos := qos
    mqttPublishRetain := retain
    mqttPublishTimeout := timeout
    mqttPublishPayloadLen := length
    mqttPublishPayloadSent := 0
    mqttPublishTopicSet := false
    mqttPublishLenSet := false

    ' Set the topic first
    topicLen := strsize(pTopic)
    str.sprintf2(@tmp, @"AT+CMQTTTOPIC=%d,%d\000", clientNum, topicLen)
    r := runCommandWithPayload(@tmp, pTopic, topicLen)
    if r <> RESULT_OK
        return r
    mqttPublishTopicSet := true

    ' Set the payload length
    str.sprintf2(@tmp, @"AT+CMQTTPAYLOAD=%d,%d\000", clientNum, length)
    inWaitingForPrompt := true
    inWaitingPayloadLen := length
    payloadSent := 0
    payload_flush()
    r := runBlindCommandForPrompt(@tmp)
    mqttPublishLenSet := true

    r := RESULT_OK


PUB mqttPublishStreamDone() : r | tmp[64]
'' Complete the MQTT publish stream and send the publish command

    repeat while inWaitingCompleted == false
    str.sprintf4(@tmp, @"AT+CMQTTPUB=%d,%d,%d,%d\000", mqttPublishClientNum, mqttPublishQos, mqttPublishTimeout, mqttPublishRetain)
    r := runCommand(@tmp)


PUB mqttPublishStreamByte(byteValue) : remaining | r
'' Send a single byte in the MQTT publish stream
'' Returns number of bytes remaining to send (including this one), or -1 on error

    ifnot mqttPublishTopicSet
        return -1
    ifnot mqttPublishLenSet
        return -1

    ' Check if we've sent all bytes
    if mqttPublishPayloadSent >= mqttPublishPayloadLen
        return 0

    ' Send the byte via the payload stream mechanism
    ' We reuse the existing payload buffer and feedPayload mechanism
    if payload_put(byteValue)
        mqttPublishPayloadSent++
        return mqttPublishPayloadLen - mqttPublishPayloadSent
    else
        ' Buffer full - caller should wait and try again
        debug("full")
        return -1


PUB mqttPublishStreamStr(pStr) : remaining | len, i, success
'' Send a string in the MQTT publish stream
'' Returns number of bytes remaining to send (including this string), or -1 on error

    ifnot mqttPublishTopicSet
        return -1
    ifnot mqttPublishLenSet
        return -1

    len := strsize(pStr)
    if mqttPublishPayloadSent + len > mqttPublishPayloadLen
        ' Truncate to fit remaining space
        len := mqttPublishPayloadLen - mqttPublishPayloadSent
        if len <= 0
            return 0

    ' Send each character
    repeat i from 0 to len-1
        success := payload_put(BYTE[pStr][i])
        if success
            mqttPublishPayloadSent++
        else
            ' Buffer full - return how many bytes we still need to send (including current)
            return (mqttPublishPayloadLen - mqttPublishPayloadSent) + (len - i)
    repeat

    return mqttPublishPayloadLen - mqttPublishPayloadSent


PUB mqttDisconnect(clientNum, timeout) : r | tmp[64]
    str.sprintf2(@tmp, @"AT+CMQTTDISC=%d,%d\000", clientNum, timeout)
    r := runCommand(@tmp)


PUB mqttReleaseClient(clientNum) : r | tmp[64]
    str.sprintf1(@tmp, @"AT+CMQTTREL=%d\000", clientNum)
    r := runCommand(@tmp)


PUB definePdpContext(cid, pAPN) : r | tmp[128], args[6]
    args[0] := cid
    args[1] := 34
    args[2] := 34
    args[3] := 34
    args[4] := pAPN
    args[5] := 34
    str.sprintf(@tmp, @"AT+CGDCONT=%d,%cIP%c,%c%s%c\000", @args)
    r := runCommand(@tmp)


PUB netOpen() : r
    r := runCommand(@"AT+NETOPEN")


PUB netClose() : r
    r := runCommand(@"AT+NETCLOSE")
